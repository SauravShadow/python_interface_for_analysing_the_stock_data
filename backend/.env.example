# Copy this to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/flattrade_dashboard

# Absolute path to your FlatTrade_API-ReadyToUse project (local path; in Docker this is /app)
FLATTRADE_PROJECT_PATH=/home/subaru/projects/FlatTrade_API-ReadyToUse

# Directory to store trained ML model files
ML_MODELS_DIR=/home/subaru/projects/python_dashboard/backend/ml_models

# CORS origins (Next.js dev server + production)
CORS_ORIGINS=["http://localhost:3000","http://100.x.x.x:3000"]

# Secret key for signing internal state (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_generate_a_real_secret

# Redis broker URL (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Directory for CSV market data files
DATA_DIR=./data
